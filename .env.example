# ========================
# APPLIXYBOT - Environment Variables
# Copy this to .env and fill in your values
# ========================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_token_from_@BotFather

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# --- AI (NVIDIA NIM API) ---
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY_70B=nvapi-your-70b-key
NVIDIA_API_KEY_8B=nvapi-your-8b-key
NVIDIA_MODEL_70B=meta/llama3-70b-instruct
NVIDIA_MODEL_8B=meta/llama3-8b-instruct

# --- Payments (Razorpay - Test Mode) ---
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_secret

# --- App Config ---
ENVIRONMENT=development
MAX_COVER_LETTERS_FREE=3
MAX_AUTO_APPLIES_PER_DAY=10
